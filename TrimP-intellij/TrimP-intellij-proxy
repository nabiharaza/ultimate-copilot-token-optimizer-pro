#!/bin/bash
# TrimP-intellij-proxy — Launch script for IntelliJ/PyCharm Copilot Chat compression proxy

set -e

# Get the directory of this script
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(dirname "$SCRIPT_DIR")"

# Default values
PORT=8765
HOST="127.0.0.1"
INTEGRATION_ID="intellij-chat"

# Parse arguments
while [[ $# -gt 0 ]]; do
    case $1 in
        --port|-p)
            PORT="$2"
            shift 2
            ;;
        --host|-h)
            HOST="$2"
            shift 2
            ;;
        --integration-id|-i)
            INTEGRATION_ID="$2"
            shift 2
            ;;
        --help)
            echo "Usage: $0 [OPTIONS]"
            echo ""
            echo "Options:"
            echo "  --port, -p PORT          Proxy port (default: 8765)"
            echo "  --host, -h HOST          Proxy host (default: 127.0.0.1)"
            echo "  --integration-id, -i ID  Copilot integration ID (default: intellij-chat)"
            echo "  --help                   Show this help"
            echo ""
            echo "Environment variables:"
            echo "  GITHUB_COPILOT_TOKEN     Your GitHub Copilot API token"
            echo "  GH_TOKEN                 GitHub CLI token (fallback)"
            echo "  TRIMP_COMPRESSION_LEVEL  Compression level 1-5 (default: 3)"
            exit 0
            ;;
        *)
            echo "Unknown option: $1"
            echo "Use --help for usage"
            exit 1
            ;;
    esac
done

# Check for GitHub token
if [[ -z "$GITHUB_COPILOT_TOKEN" && -z "$GH_TOKEN" ]]; then
    echo "⚠️  No GitHub token found in environment"
    echo "   Trying to get token from 'gh auth token'..."
    if command -v gh &> /dev/null; then
        TOKEN=$(gh auth token 2>/dev/null || true)
        if [[ -n "$TOKEN" ]]; then
            export GITHUB_COPILOT_TOKEN="$TOKEN"
            echo "   ✓ Using token from gh CLI"
        else
            echo "   ✗ Could not get token from gh CLI"
            echo "   Please run: gh auth login"
            echo "   Or set: export GITHUB_COPILOT_TOKEN=your_token"
            exit 1
        fi
    else
        echo "   ✗ gh CLI not found"
        echo "   Please install GitHub CLI or set GITHUB_COPILOT_TOKEN"
        exit 1
    fi
fi

# Export integration ID
export COPILOT_INTEGRATION_ID="$INTEGRATION_ID"

echo "🚀 Starting TrimP IntelliJ/PyCharm Proxy"
echo "   Host: $HOST"
echo "   Port: $PORT"
echo "   Integration: $INTEGRATION_ID"
echo ""
echo "📋 Configure PyCharm/IntelliJ:"
echo "   Settings → Appearance & Behavior → System Settings → HTTP Proxy"
echo "   Manual proxy configuration:"
echo "     HTTP: Host=localhost, Port=$PORT"
echo "     ✅ Use this proxy server for all protocols"
echo "   Apply → OK → Restart PyCharm"
echo ""
echo "   Or launch from this terminal:"
echo "     export HTTP_PROXY=http://localhost:$PORT"
echo "     export HTTPS_PROXY=http://localhost:$PORT"
echo "     pycharm"
echo ""
echo "📊 View savings: TrimP dashboard (in another terminal)"
echo "🔍 Monitor:      TrimP monitor"
echo ""
echo "Press Ctrl+C to stop"
echo ""

# Run the proxy
cd "$PROJECT_ROOT"
exec python3 -m TrimP.intellij_proxy --host "$HOST" --port "$PORT"